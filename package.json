{
  "name": "tech-brief-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean && rm -rf node_modules",
    "dev": "turbo dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@tech-brief-ai/eslint-config": "*",
    "@tech-brief-ai/typescript-config": "*",
    "metro": "0.81.5",
    "metro-cache": "0.81.5",
    "metro-config": "0.81.5",
    "metro-transform-worker": "0.81.5",
    "prettier": "^3.3.3",
    "turbo": "^2.0.11",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "expo": "52.0.49",
    "@expo/cli": "0.22.28",
    "@expo/dom-webview": "0.1.0",
    "@expo/metro-config": "0.19.12",
    "babel-preset-expo": "12.0.12",
    "react-native": "0.76.9",
    "@react-native/metro-config": "0.76.9",
    "metro": "0.81.5",
    "metro-cache": "0.81.5",
    "metro-config": "0.81.5",
    "metro-transform-worker": "0.81.5"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}
